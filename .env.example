# =============================================================================
# Sarvantaryami Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration (Ollama)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# Chat/Reasoning Model
# Development: llama3.2:3b (fast, ~2GB) - recommended for local testing
# Production: llama3.1:8b-instruct (accurate, ~5GB) - recommended for enterprise
LLM_MODEL=llama3.2:3b

# Embedding Model (for semantic search, intent routing, RAG retrieval)
# Recommended: nomic-embed-text (fast, ~274MB, good quality)
EMBEDDING_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Database Configuration (Entity Service)
# -----------------------------------------------------------------------------
ENT_PG_DB=entdb
ENT_PG_USER=entity
ENT_PG_PASSWORD=password
ENT_PG_DB_PORT=5434
ENT_PG_HOST=localhost

# Database URI for Agent
# LOCAL development: use localhost
# DOCKER: use host.docker.internal
DB_URI=postgresql+psycopg2://entity:password@localhost:5434/entdb

# -----------------------------------------------------------------------------
# Vector Store (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_collection

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
API_TITLE=Sarvantaryamin Agent
API_VERSION=v1
